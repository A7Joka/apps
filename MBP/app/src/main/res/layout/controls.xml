<LinearLayout
	xmlns:android="http://schemas.android.com/apk/res/android"
	xmlns:app="http://schemas.android.com/apk/res-auto"
	xmlns:tools="http://schemas.android.com/tools"
	android:layout_width="match_parent"
	android:layout_height="match_parent"
	android:orientation="vertical">
	<LinearLayout
		android:id="@+id/linear1"
		android:layout_width="match_parent"
		android:layout_height="match_parent"
		android:gravity="center_horizontal|center_vertical"
		android:orientation="vertical"
		android:layout_weight="1">
		<FrameLayout
			android:id="@+id/controlButtons"
			android:layout_width="match_parent"
			android:layout_height="match_parent"
			android:gravity="center_horizontal|center_vertical"
			android:orientation="vertical"
			android:layout_gravity="center_horizontal|center_vertical">
			<LinearLayout
				android:id="@+id/controlButtons_top"
				android:layout_width="match_parent"
				android:layout_height="wrap_content"
				android:padding="8dp"
				android:orientation="horizontal"
				android:layout_gravity="top">
				<ImageView
					android:id="@+id/btn_back"
					android:focusable="false"
					android:layout_width="30dp"
					android:layout_height="30dp"
					android:layout_margin="4dp"
					android:padding="4dp"
					android:src="@drawable/ic_back"
					android:scaleType="fitCenter" />
				<TextView
					android:id="@+id/file_name_tv"
					android:focusable="false"
					android:layout_width="wrap_content"
					android:layout_height="30dp"
					android:layout_marginLeft="2dp"
					android:layout_marginTop="4dp"
					android:layout_marginRight="4dp"
					android:layout_marginBottom="4dp"
					android:gravity="center_horizontal|center_vertical"
					android:text="name_video"
					android:textSize="20sp"
					android:textStyle="bold"
					android:textColor="#FFFFFF" />
			</LinearLayout>
			<LinearLayout
				android:id="@+id/controlButtons_center"
				android:layout_width="match_parent"
				android:layout_height="match_parent"
				android:padding="8dp"
				android:gravity="center_horizontal|center_vertical"
				android:orientation="horizontal"
				android:layout_gravity="center_vertical"
				android:layout_weight="1">
				<ImageView
					android:id="@+id/backward_10"
					android:focusable="false"
					android:layout_width="30dp"
					android:layout_height="30dp"
					android:layout_margin="4dp"
					android:src="@drawable/ic_rewind"
					android:scaleType="fitCenter"
					style="@style/ExoStyledControls.Button.Center.PlayPause"
					android:contentDescription="Skip10secondsbackward" />
				<LinearLayout
					android:id="@+id/PlayPause"
					android:layout_width="50dp"
					android:layout_height="50dp"
					android:padding="8dp"
					android:gravity="center_horizontal|center_vertical"
					android:orientation="vertical">
					<ImageView
						android:id="@+id/exo_play_pause"
						android:focusable="false"
						android:layout_width="30dp"
						android:layout_height="30dp"
						android:layout_margin="4dp"
						android:src="@drawable/ic_pause"
						android:scaleType="fitCenter" />
				</LinearLayout>
				<ImageView
					android:id="@+id/forward_10"
					android:focusable="false"
					android:layout_width="30dp"
					android:layout_height="30dp"
					android:layout_margin="4dp"
					android:src="@drawable/ic_forward"
					android:scaleType="fitCenter"
					style="@style/ExoStyledControls.Button.Center.PlayPause"
					android:contentDescription="Skip10secondsforward" />
			</LinearLayout>
			<LinearLayout
				android:id="@+id/linear2"
				android:layout_width="match_parent"
				android:layout_height="wrap_content"
				android:orientation="vertical"
				android:layout_gravity="bottom">
				<com.google.android.exoplayer2.ui.DefaultTimeBar
					android:id="@+id/exo_progress"
					android:layout_width="match_parent"
					android:layout_height="wrap_content"
					android:paddingLeft="8dp"
					android:paddingTop="8dp"
					android:paddingRight="8dp"
					android:paddingBottom="4dp"
					android:gravity="bottom"
					android:orientation="horizontal"
					android:layout_gravity="top"
					app:buffered_color="#ff95989f"
					app:played_color="#ff008b8b"
					app:unplayed_color="#ffe0e0e0" />
				<LinearLayout
					android:id="@+id/exo_basic_controls"
					android:layout_width="match_parent"
					android:layout_height="wrap_content"
					android:paddingLeft="8dp"
					android:paddingRight="8dp"
					android:paddingBottom="8dp"
					android:gravity="right|center_vertical"
					android:orientation="horizontal"
					android:layout_gravity="bottom">
					<LinearLayout
						android:id="@+id/exo_time"
						android:layout_width="wrap_content"
						android:layout_height="wrap_content"
						android:gravity="left|center_vertical"
						android:orientation="horizontal"
						android:layout_weight="1">
						<TextView
							android:id="@+id/exo_position"
							android:focusable="false"
							android:layout_width="wrap_content"
							android:layout_height="wrap_content"
							android:paddingLeft="6dp"
							android:paddingTop="4dp"
							android:paddingRight="6dp"
							android:paddingBottom="4dp"
							android:text="00:00"
							android:textSize="12sp"
							android:textColor="#FFFFFF" />
						<TextView
							android:id="@+id/txt"
							android:focusable="false"
							android:layout_width="wrap_content"
							android:layout_height="wrap_content"
							android:text="/"
							android:textSize="12sp"
							android:textColor="#FFFFFF" />
						<TextView
							android:id="@+id/exo_duration"
							android:focusable="false"
							android:layout_width="wrap_content"
							android:layout_height="wrap_content"
							android:paddingLeft="6dp"
							android:paddingTop="4dp"
							android:paddingRight="6dp"
							android:paddingBottom="4dp"
							android:text="00:00"
							android:textSize="12sp"
							android:textColor="#FFFFFF" />
					</LinearLayout>
					<ImageView
						android:id="@+id/btn_servers"
						android:focusable="false"
						android:layout_width="28dp"
						android:layout_height="28dp"
						android:layout_marginLeft="6dp"
						android:layout_marginTop="4dp"
						android:layout_marginRight="6dp"
						android:layout_marginBottom="4dp"
						android:padding="2dp"
						android:src="@drawable/ic_servers"
						android:scaleType="fitCenter" />
					<ImageView
						android:id="@+id/exo_settings"
						android:focusable="false"
						android:layout_width="0dp"
						android:layout_height="0dp"
						android:src="@drawable/default_image"
						android:scaleType="center" />
					<ImageView
						android:id="@+id/btn_screen"
						android:focusable="false"
						android:layout_width="28dp"
						android:layout_height="28dp"
						android:layout_marginLeft="6dp"
						android:layout_marginTop="4dp"
						android:layout_marginRight="6dp"
						android:layout_marginBottom="4dp"
						android:padding="3dp"
						android:src="@drawable/ic_full_screen"
						android:scaleType="fitCenter" />
					<ImageView
						android:id="@+id/btn_rotate"
						android:focusable="false"
						android:layout_width="28dp"
						android:layout_height="28dp"
						android:layout_marginLeft="6dp"
						android:layout_marginTop="4dp"
						android:layout_marginRight="6dp"
						android:layout_marginBottom="4dp"
						android:padding="1dp"
						android:src="@drawable/ic_rotate"
						android:scaleType="fitCenter" />
					<ImageView
						android:id="@+id/btn_cast"
						android:focusable="false"
						android:layout_width="28dp"
						android:layout_height="28dp"
						android:layout_marginLeft="6dp"
						android:layout_marginTop="4dp"
						android:layout_marginRight="6dp"
						android:layout_marginBottom="4dp"
						android:padding="1dp"
						android:src="@drawable/ic_cast"
						android:scaleType="fitCenter" />
					<ImageView
						android:id="@+id/btn_pip"
						android:focusable="false"
						android:layout_width="28dp"
						android:layout_height="28dp"
						android:layout_marginLeft="6dp"
						android:layout_marginTop="4dp"
						android:layout_marginRight="6dp"
						android:layout_marginBottom="4dp"
						android:padding="3dp"
						android:src="@drawable/ic_pip"
						android:scaleType="fitCenter" />
					<ImageView
						android:id="@+id/btn_audio"
						android:focusable="false"
						android:layout_width="28dp"
						android:layout_height="28dp"
						android:layout_marginLeft="6dp"
						android:layout_marginTop="4dp"
						android:layout_marginRight="6dp"
						android:layout_marginBottom="4dp"
						android:padding="1dp"
						android:src="@drawable/ic_mic"
						android:scaleType="fitCenter" />
					<ImageView
						android:id="@+id/btn_quality"
						android:focusable="false"
						android:layout_width="28dp"
						android:layout_height="28dp"
						android:layout_marginLeft="6dp"
						android:layout_marginTop="4dp"
						android:layout_marginRight="6dp"
						android:layout_marginBottom="4dp"
						android:padding="3dp"
						android:src="@drawable/ic_settings"
						android:scaleType="fitCenter" />
				</LinearLayout>
			</LinearLayout>
		</FrameLayout>
	</LinearLayout>
</LinearLayout>
