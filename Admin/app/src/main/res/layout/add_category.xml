<androidx.coordinatorlayout.widget.CoordinatorLayout
	xmlns:android="http://schemas.android.com/apk/res/android"
	xmlns:app="http://schemas.android.com/apk/res-auto"
	xmlns:tools="http://schemas.android.com/tools"
	android:id="@+id/_coordinator"
	android:layout_width="match_parent"
	android:layout_height="match_parent">
	<com.google.android.material.appbar.AppBarLayout
		android:id="@+id/_app_bar"
		android:layout_width="match_parent"
		android:layout_height="wrap_content"
		android:theme="@style/AppTheme.AppBarOverlay">
		<androidx.appcompat.widget.Toolbar
			android:id="@+id/_toolbar"
			android:layout_width="match_parent"
			android:layout_height="?attr/actionBarSize"
			android:background="?attr/colorPrimary"
			app:popupTheme="@style/AppTheme.PopupOverlay" />
	</com.google.android.material.appbar.AppBarLayout>
	<LinearLayout
		android:layout_width="match_parent"
		android:layout_height="match_parent"
		android:orientation="vertical"
		app:layout_behavior="@string/appbar_scrolling_view_behavior">
		<LinearLayout
			android:id="@+id/linear68"
			android:layout_width="match_parent"
			android:layout_height="match_parent"
			android:background="#EEEEEE"
			android:gravity="center_horizontal|center_vertical"
			android:orientation="vertical">
			<ScrollView
				android:id="@+id/vscroll1"
				android:layout_width="match_parent"
				android:layout_height="wrap_content"
				android:background="#EEEEEE"
				android:layout_gravity="center_horizontal|center_vertical">
				<LinearLayout
					android:id="@+id/linear23"
					android:layout_width="match_parent"
					android:layout_height="wrap_content"
					android:background="#EEEEEE"
					android:gravity="center_horizontal|center_vertical"
					android:orientation="vertical">
					<LinearLayout
						android:id="@+id/linear46"
						android:layout_width="match_parent"
						android:layout_height="match_parent"
						android:padding="10dp"
						android:background="#EEEEEE"
						android:gravity="center_horizontal|center_vertical"
						android:orientation="vertical">
						<LinearLayout
							android:id="@+id/linear47"
							android:layout_width="match_parent"
							android:layout_height="wrap_content"
							android:layout_marginBottom="5dp"
							android:padding="10dp"
							android:background="#BDBDBD"
							android:orientation="horizontal">
							<LinearLayout
								android:id="@+id/linear48"
								android:layout_width="match_parent"
								android:layout_height="wrap_content"
								android:layout_marginRight="5dp"
								android:padding="8dp"
								android:background="#757575"
								android:gravity="center_horizontal|center_vertical"
								android:orientation="vertical"
								android:layout_weight="1">
								<ImageView
									android:id="@+id/imageview1"
									android:layout_width="70dp"
									android:layout_height="70dp"
									android:src="@drawable/smartphone"
									android:scaleType="fitCenter" />
								<TextView
									android:id="@+id/textview18"
									android:layout_width="wrap_content"
									android:layout_height="wrap_content"
									android:padding="8dp"
									android:text="صيانة"
									android:textSize="14sp"
									android:textStyle="bold"
									android:textColor="#FFFFFF" />
							</LinearLayout>
							<LinearLayout
								android:id="@+id/linear50"
								android:layout_width="match_parent"
								android:layout_height="wrap_content"
								android:layout_marginLeft="5dp"
								android:layout_marginRight="5dp"
								android:padding="8dp"
								android:background="#757575"
								android:gravity="center_horizontal|center_vertical"
								android:orientation="vertical"
								android:layout_weight="1">
								<ImageView
									android:id="@+id/imageview2"
									android:layout_width="70dp"
									android:layout_height="70dp"
									android:src="@drawable/socialmedia"
									android:scaleType="fitCenter" />
								<TextView
									android:id="@+id/textview19"
									android:layout_width="wrap_content"
									android:layout_height="wrap_content"
									android:padding="8dp"
									android:text="تحديثات"
									android:textSize="14sp"
									android:textStyle="bold"
									android:textColor="#FFFFFF" />
							</LinearLayout>
							<LinearLayout
								android:id="@+id/linear51"
								android:layout_width="match_parent"
								android:layout_height="wrap_content"
								android:layout_marginLeft="5dp"
								android:padding="8dp"
								android:background="#757575"
								android:gravity="center_horizontal|center_vertical"
								android:orientation="vertical"
								android:layout_weight="1">
								<ImageView
									android:id="@+id/imageview3"
									android:layout_width="70dp"
									android:layout_height="70dp"
									android:src="@drawable/alarm"
									android:scaleType="fitCenter" />
								<TextView
									android:id="@+id/textview20"
									android:layout_width="wrap_content"
									android:layout_height="wrap_content"
									android:padding="8dp"
									android:text="اشعارات"
									android:textSize="14sp"
									android:textStyle="bold"
									android:textColor="#FFFFFF" />
							</LinearLayout>
						</LinearLayout>
						<LinearLayout
							android:id="@+id/linear74"
							android:layout_width="match_parent"
							android:layout_height="wrap_content"
							android:layout_marginTop="5dp"
							android:layout_marginBottom="5dp"
							android:padding="8dp"
							android:background="#757575"
							android:gravity="center_horizontal|center_vertical"
							android:orientation="vertical"
							android:layout_weight="1">
							<ImageView
								android:id="@+id/imageview18"
								android:layout_width="70dp"
								android:layout_height="70dp"
								android:src="@drawable/link"
								android:scaleType="fitCenter" />
							<TextView
								android:id="@+id/textview35"
								android:layout_width="wrap_content"
								android:layout_height="wrap_content"
								android:padding="8dp"
								android:text="تعديل روابط"
								android:textSize="14sp"
								android:textStyle="bold"
								android:textColor="#FFFFFF" />
						</LinearLayout>
						<LinearLayout
							android:id="@+id/linear64"
							android:layout_width="match_parent"
							android:layout_height="wrap_content"
							android:layout_marginTop="5dp"
							android:layout_marginBottom="5dp"
							android:background="#757575"
							android:orientation="horizontal">
							<LinearLayout
								android:id="@+id/linear66"
								android:layout_width="match_parent"
								android:layout_height="wrap_content"
								android:padding="10dp"
								android:background="#757575"
								android:gravity="center_horizontal|center_vertical"
								android:orientation="vertical"
								android:layout_weight="1">
								<ImageView
									android:id="@+id/imageview14"
									android:layout_width="70dp"
									android:layout_height="70dp"
									android:src="@drawable/mobilesecurity"
									android:scaleType="fitCenter" />
								<TextView
									android:id="@+id/textview31"
									android:layout_width="wrap_content"
									android:layout_height="wrap_content"
									android:padding="8dp"
									android:text="كود التفعيل"
									android:textSize="14sp"
									android:textStyle="bold"
									android:textColor="#FFFFFF" />
							</LinearLayout>
						</LinearLayout>
						<LinearLayout
							android:id="@+id/linear75"
							android:layout_width="match_parent"
							android:layout_height="wrap_content"
							android:layout_marginTop="5dp"
							android:layout_marginBottom="5dp"
							android:padding="10dp"
							android:background="#757575"
							android:gravity="center_horizontal|center_vertical"
							android:orientation="vertical"
							android:layout_weight="1">
							<ImageView
								android:id="@+id/imageview19"
								android:layout_width="70dp"
								android:layout_height="70dp"
								android:src="@drawable/soccer"
								android:scaleType="fitCenter" />
							<TextView
								android:id="@+id/textview36"
								android:layout_width="wrap_content"
								android:layout_height="wrap_content"
								android:padding="8dp"
								android:text="المبارايات"
								android:textSize="14sp"
								android:textStyle="bold"
								android:textColor="#FFFFFF" />
						</LinearLayout>
						<LinearLayout
							android:id="@+id/linear56"
							android:layout_width="match_parent"
							android:layout_height="wrap_content"
							android:layout_marginTop="5dp"
							android:layout_marginBottom="5dp"
							android:padding="10dp"
							android:background="#BDBDBD"
							android:orientation="horizontal">
							<LinearLayout
								android:id="@+id/linear58"
								android:layout_width="match_parent"
								android:layout_height="wrap_content"
								android:layout_marginRight="5dp"
								android:padding="8dp"
								android:background="#757575"
								android:gravity="center_horizontal|center_vertical"
								android:orientation="vertical"
								android:layout_weight="1">
								<ImageView
									android:id="@+id/imageview8"
									android:layout_width="70dp"
									android:layout_height="70dp"
									android:src="@drawable/schedule"
									android:scaleType="fitCenter" />
								<TextView
									android:id="@+id/textview25"
									android:layout_width="wrap_content"
									android:layout_height="wrap_content"
									android:padding="8dp"
									android:text="الباقات"
									android:textSize="14sp"
									android:textStyle="bold"
									android:textColor="#FFFFFF" />
							</LinearLayout>
							<LinearLayout
								android:id="@+id/linear59"
								android:layout_width="match_parent"
								android:layout_height="wrap_content"
								android:layout_marginLeft="5dp"
								android:padding="8dp"
								android:background="#757575"
								android:gravity="center_horizontal|center_vertical"
								android:orientation="vertical"
								android:layout_weight="1">
								<ImageView
									android:id="@+id/imageview9"
									android:layout_width="70dp"
									android:layout_height="70dp"
									android:src="@drawable/soccerfield"
									android:scaleType="fitCenter" />
								<TextView
									android:id="@+id/textview26"
									android:layout_width="wrap_content"
									android:layout_height="wrap_content"
									android:padding="8dp"
									android:text="البطولات"
									android:textSize="14sp"
									android:textStyle="bold"
									android:textColor="#FFFFFF" />
							</LinearLayout>
						</LinearLayout>
						<LinearLayout
							android:id="@+id/linear67"
							android:layout_width="match_parent"
							android:layout_height="0dp"
							android:padding="8dp"
							android:orientation="vertical">
							<ListView
								android:id="@+id/listview1"
								android:layout_width="match_parent"
								android:layout_height="0dp"
								android:padding="8dp"
								android:choiceMode="none"
								android:layout_weight="1" />
						</LinearLayout>
						<ListView
							android:id="@+id/listview2"
							android:layout_width="match_parent"
							android:layout_height="0dp"
							android:padding="8dp"
							android:choiceMode="none" />
						<LinearLayout
							android:id="@+id/linear69"
							android:layout_width="match_parent"
							android:layout_height="wrap_content"
							android:layout_marginTop="5dp"
							android:layout_marginBottom="5dp"
							android:padding="10dp"
							android:background="#BDBDBD"
							android:orientation="horizontal">
							<LinearLayout
								android:id="@+id/linear70"
								android:layout_width="match_parent"
								android:layout_height="wrap_content"
								android:layout_marginRight="5dp"
								android:padding="8dp"
								android:background="#757575"
								android:gravity="center_horizontal|center_vertical"
								android:orientation="vertical"
								android:layout_weight="1">
								<ImageView
									android:id="@+id/imageview15"
									android:layout_width="70dp"
									android:layout_height="70dp"
									android:src="@drawable/rating_1"
									android:scaleType="fitCenter" />
								<TextView
									android:id="@+id/textview32"
									android:layout_width="wrap_content"
									android:layout_height="wrap_content"
									android:padding="8dp"
									android:text="التقيميات"
									android:textSize="14sp"
									android:textStyle="bold"
									android:textColor="#FFFFFF" />
							</LinearLayout>
							<LinearLayout
								android:id="@+id/linear71"
								android:layout_width="match_parent"
								android:layout_height="wrap_content"
								android:layout_marginLeft="5dp"
								android:padding="8dp"
								android:background="#757575"
								android:gravity="center_horizontal|center_vertical"
								android:orientation="vertical"
								android:layout_weight="1">
								<ImageView
									android:id="@+id/imageview16"
									android:layout_width="70dp"
									android:layout_height="70dp"
									android:src="@drawable/rating_2"
									android:scaleType="fitCenter" />
								<TextView
									android:id="@+id/textview33"
									android:layout_width="wrap_content"
									android:layout_height="wrap_content"
									android:padding="8dp"
									android:text="المشاكل"
									android:textSize="14sp"
									android:textStyle="bold"
									android:textColor="#FFFFFF" />
							</LinearLayout>
						</LinearLayout>
					</LinearLayout>
				</LinearLayout>
			</ScrollView>
		</LinearLayout>
	</LinearLayout>
</androidx.coordinatorlayout.widget.CoordinatorLayout>
