<LinearLayout
	xmlns:android="http://schemas.android.com/apk/res/android"
	xmlns:app="http://schemas.android.com/apk/res-auto"
	xmlns:tools="http://schemas.android.com/tools"
	android:layout_width="match_parent"
	android:layout_height="match_parent"
	android:orientation="vertical">
	<LinearLayout
		android:id="@+id/linear1"
		android:layout_width="match_parent"
		android:layout_height="wrap_content"
		android:padding="2dp"
		android:background="#78022C"
		android:orientation="vertical">
		<LinearLayout
			android:id="@+id/linear2"
			android:layout_width="match_parent"
			android:layout_height="wrap_content"
			android:layout_marginLeft="8dp"
			android:layout_marginTop="8dp"
			android:layout_marginRight="8dp"
			android:layout_marginBottom="2dp"
			android:padding="8dp"
			android:background="#E0E0E0"
			android:gravity="center_horizontal|center_vertical"
			android:orientation="vertical">
			<TextView
				android:id="@+id/textview1"
				android:focusable="false"
				android:layout_width="match_parent"
				android:layout_height="wrap_content"
				android:padding="8dp"
				android:background="#78022C"
				android:gravity="center_horizontal|center_vertical"
				android:text="معلومات المطور والمسؤول"
				android:textSize="20sp"
				android:textStyle="bold"
				android:textColor="#FFFFFF" />
			<ImageView
				android:id="@+id/imageview1"
				android:focusable="false"
				android:layout_width="120dp"
				android:layout_height="120dp"
				android:layout_margin="12dp"
				android:src="@drawable/eng"
				android:scaleType="fitCenter" />
			<TextView
				android:id="@+id/textview2"
				android:focusable="false"
				android:layout_width="wrap_content"
				android:layout_height="wrap_content"
				android:padding="8dp"
				android:text="ENG Abdallah Hussein (Egypt) 🇪🇬"
				android:textSize="16sp"
				android:textStyle="bold"
				android:textColor="#78022C" />
			<TextView
				android:id="@+id/textview3"
				android:focusable="false"
				android:layout_width="wrap_content"
				android:layout_height="wrap_content"
				android:padding="8dp"
				android:text="مطور ويب ومبرمج تطبيقات وبرامج"
				android:textSize="14sp"
				android:textStyle="bold"
				android:textColor="#78022C" />
		</LinearLayout>
		<LinearLayout
			android:id="@+id/linear3"
			android:layout_width="match_parent"
			android:layout_height="wrap_content"
			android:layout_margin="8dp"
			android:background="#E0E0E0"
			android:gravity="center_horizontal|center_vertical"
			android:orientation="horizontal">
			<LinearLayout
				android:id="@+id/linear5"
				android:layout_width="match_parent"
				android:layout_height="wrap_content"
				android:padding="8dp"
				android:gravity="center_horizontal|center_vertical"
				android:orientation="vertical"
				android:layout_weight="1">
				<TextView
					android:id="@+id/textview6"
					android:focusable="false"
					android:layout_width="match_parent"
					android:layout_height="wrap_content"
					android:padding="8dp"
					android:background="#78022C"
					android:gravity="center_horizontal|center_vertical"
					android:text="معلومات المسؤول"
					android:textSize="20sp"
					android:textStyle="bold"
					android:textColor="#FFFFFF" />
				<ImageView
					android:id="@+id/imageview3"
					android:focusable="false"
					android:layout_width="120dp"
					android:layout_height="120dp"
					android:layout_margin="12dp"
					android:src="@drawable/logoapp"
					android:scaleType="fitCenter" />
				<TextView
					android:id="@+id/textview7"
					android:focusable="false"
					android:layout_width="wrap_content"
					android:layout_height="wrap_content"
					android:padding="8dp"
					android:text="Bassam Samier (Egypt) 🇪🇬"
					android:textSize="16sp"
					android:textStyle="bold"
					android:textColor="#78022C" />
			</LinearLayout>
			<LinearLayout
				android:id="@+id/linear4"
				android:layout_width="match_parent"
				android:layout_height="wrap_content"
				android:padding="8dp"
				android:gravity="center_horizontal|center_vertical"
				android:orientation="vertical"
				android:layout_weight="1">
				<TextView
					android:id="@+id/textview4"
					android:focusable="false"
					android:layout_width="match_parent"
					android:layout_height="wrap_content"
					android:padding="8dp"
					android:background="#78022C"
					android:gravity="center_horizontal|center_vertical"
					android:text="معلومات المسؤول"
					android:textSize="20sp"
					android:textStyle="bold"
					android:textColor="#FFFFFF" />
				<ImageView
					android:id="@+id/imageview2"
					android:focusable="false"
					android:layout_width="120dp"
					android:layout_height="120dp"
					android:layout_margin="12dp"
					android:src="@drawable/logoapp"
					android:scaleType="fitCenter" />
				<TextView
					android:id="@+id/textview5"
					android:focusable="false"
					android:layout_width="wrap_content"
					android:layout_height="wrap_content"
					android:padding="8dp"
					android:text="Nabil Taleb (Algeria) 🇩🇿 "
					android:textSize="16sp"
					android:textStyle="bold"
					android:textColor="#78022C" />
			</LinearLayout>
		</LinearLayout>
	</LinearLayout>
</LinearLayout>
