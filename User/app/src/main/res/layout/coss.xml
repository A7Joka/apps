<LinearLayout
	xmlns:android="http://schemas.android.com/apk/res/android"
	xmlns:app="http://schemas.android.com/apk/res-auto"
	xmlns:tools="http://schemas.android.com/tools"
	android:layout_width="match_parent"
	android:layout_height="match_parent"
	android:orientation="vertical">
	<LinearLayout
		android:id="@+id/linear1"
		android:layout_width="match_parent"
		android:layout_height="wrap_content"
		android:padding="6dp"
		android:background="#E0E0E0"
		android:gravity="center_horizontal|center_vertical"
		android:orientation="vertical">
		<LinearLayout
			android:id="@+id/linear2"
			android:layout_width="match_parent"
			android:layout_height="wrap_content"
			android:layout_margin="6dp"
			android:padding="8dp"
			android:background="#BDBDBD"
			android:gravity="right|center_vertical"
			android:orientation="horizontal">
			<TextView
				android:id="@+id/textview1"
				android:focusable="false"
				android:layout_width="wrap_content"
				android:layout_height="wrap_content"
				android:layout_marginRight="4dp"
				android:text="TextView"
				android:textSize="14sp"
				android:textColor="#000000" />
			<TextView
				android:id="@+id/textview0"
				android:focusable="false"
				android:layout_width="100dp"
				android:layout_height="wrap_content"
				android:layout_marginRight="8dp"
				android:text="البطولة"
				android:textSize="16sp"
				android:textStyle="bold"
				android:textColor="#000000" />
			<ImageView
				android:id="@+id/imageview1"
				android:focusable="false"
				android:layout_width="38dp"
				android:layout_height="38dp"
				android:src="@drawable/eng_5"
				android:scaleType="fitCenter" />
		</LinearLayout>
		<LinearLayout
			android:id="@+id/linear3"
			android:layout_width="match_parent"
			android:layout_height="wrap_content"
			android:layout_margin="6dp"
			android:padding="8dp"
			android:background="#BDBDBD"
			android:gravity="right|center_vertical"
			android:orientation="horizontal">
			<TextView
				android:id="@+id/textview2"
				android:focusable="false"
				android:layout_width="wrap_content"
				android:layout_height="wrap_content"
				android:layout_marginRight="4dp"
				android:text="TextView"
				android:textSize="14sp"
				android:textColor="#000000" />
			<TextView
				android:id="@+id/textview00"
				android:focusable="false"
				android:layout_width="100dp"
				android:layout_height="wrap_content"
				android:layout_marginRight="8dp"
				android:text="القنوات الناقلة"
				android:textSize="16sp"
				android:textStyle="bold"
				android:textColor="#000000" />
			<ImageView
				android:id="@+id/imageview2"
				android:focusable="false"
				android:layout_width="38dp"
				android:layout_height="38dp"
				android:src="@drawable/eng_3"
				android:scaleType="fitCenter" />
		</LinearLayout>
		<LinearLayout
			android:id="@+id/linear4"
			android:layout_width="match_parent"
			android:layout_height="wrap_content"
			android:layout_margin="6dp"
			android:padding="8dp"
			android:background="#BDBDBD"
			android:gravity="right|center_vertical"
			android:orientation="horizontal">
			<TextView
				android:id="@+id/textview3"
				android:focusable="false"
				android:layout_width="wrap_content"
				android:layout_height="wrap_content"
				android:layout_marginRight="4dp"
				android:text="TextView"
				android:textSize="14sp"
				android:textColor="#000000" />
			<TextView
				android:id="@+id/textview000"
				android:focusable="false"
				android:layout_width="100dp"
				android:layout_height="wrap_content"
				android:layout_marginRight="8dp"
				android:text="المعلق"
				android:textSize="16sp"
				android:textStyle="bold"
				android:textColor="#000000" />
			<ImageView
				android:id="@+id/imageview3"
				android:focusable="false"
				android:layout_width="38dp"
				android:layout_height="38dp"
				android:src="@drawable/eng_4"
				android:scaleType="fitCenter" />
		</LinearLayout>
		<LinearLayout
			android:id="@+id/linear5"
			android:layout_width="match_parent"
			android:layout_height="wrap_content"
			android:layout_margin="6dp"
			android:padding="8dp"
			android:background="#BDBDBD"
			android:gravity="right|center_vertical"
			android:orientation="horizontal">
			<TextView
				android:id="@+id/textview4"
				android:focusable="false"
				android:layout_width="wrap_content"
				android:layout_height="wrap_content"
				android:layout_marginRight="4dp"
				android:text="TextView"
				android:textSize="14sp"
				android:textColor="#000000" />
			<TextView
				android:id="@+id/textview0000"
				android:focusable="false"
				android:layout_width="100dp"
				android:layout_height="wrap_content"
				android:layout_marginRight="8dp"
				android:text="الملعب"
				android:textSize="16sp"
				android:textStyle="bold"
				android:textColor="#000000" />
			<ImageView
				android:id="@+id/imageview4"
				android:focusable="false"
				android:layout_width="38dp"
				android:layout_height="38dp"
				android:src="@drawable/eng_2"
				android:scaleType="fitCenter" />
		</LinearLayout>
		<LinearLayout
			android:id="@+id/linear6"
			android:layout_width="match_parent"
			android:layout_height="wrap_content"
			android:layout_margin="6dp"
			android:padding="8dp"
			android:background="#BDBDBD"
			android:gravity="right|center_vertical"
			android:orientation="horizontal">
			<TextView
				android:id="@+id/textview5"
				android:focusable="false"
				android:layout_width="wrap_content"
				android:layout_height="wrap_content"
				android:layout_marginRight="4dp"
				android:text="TextView"
				android:textSize="14sp"
				android:textColor="#000000" />
			<TextView
				android:id="@+id/textview00000"
				android:focusable="false"
				android:layout_width="100dp"
				android:layout_height="wrap_content"
				android:layout_marginRight="8dp"
				android:text="التوقيت"
				android:textSize="16sp"
				android:textStyle="bold"
				android:textColor="#000000" />
			<ImageView
				android:id="@+id/imageview5"
				android:focusable="false"
				android:layout_width="38dp"
				android:layout_height="38dp"
				android:src="@drawable/eng_1"
				android:scaleType="fitCenter" />
		</LinearLayout>
		<Button
			android:id="@+id/button1"
			android:layout_width="match_parent"
			android:layout_height="wrap_content"
			android:layout_margin="6dp"
			android:padding="8dp"
			android:background="#78022C"
			android:text="مشاهدة المباراة"
			android:textSize="18sp"
			android:textColor="#FFFFFF" />
	</LinearLayout>
</LinearLayout>
