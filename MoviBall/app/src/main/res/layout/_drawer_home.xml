<LinearLayout
	xmlns:android="http://schemas.android.com/apk/res/android"
	xmlns:app="http://schemas.android.com/apk/res-auto"
	xmlns:tools="http://schemas.android.com/tools"
	android:layout_width="match_parent"
	android:layout_height="match_parent"
	android:orientation="vertical">
	<LinearLayout
		android:id="@+id/lin_draw"
		android:layout_width="240dp"
		android:layout_height="wrap_content"
		android:padding="8dp"
		android:gravity="center_horizontal|center_vertical"
		android:orientation="horizontal"
		android:translationX="12.0dp"
		android:translationY="12.0dp">
		<LinearLayout
			android:id="@+id/back"
			android:layout_width="260dp"
			android:layout_height="match_parent"
			android:padding="8dp"
			android:background="#242424"
			android:gravity="center_horizontal|center_vertical"
			android:orientation="vertical"
			android:layout_gravity="center_horizontal|center_vertical">
			<LinearLayout
				android:id="@+id/button1"
				android:layout_width="200dp"
				android:layout_height="55dp"
				android:layout_marginTop="4dp"
				android:layout_marginBottom="2dp"
				android:background="#131418"
				android:gravity="center_vertical"
				android:orientation="horizontal">
				<LinearLayout
					android:id="@+id/img1"
					android:layout_width="35dp"
					android:layout_height="35dp"
					android:layout_marginLeft="10dp"
					android:layout_marginRight="15dp"
					android:background="@drawable/ic_home"
					android:orientation="horizontal"
					android:layout_gravity="left|center_vertical" />
				<TextView
					android:id="@+id/t1"
					android:layout_width="wrap_content"
					android:layout_height="wrap_content"
					android:padding="8dp"
					android:text="Home"
					android:textSize="16sp"
					android:textColor="#FFFFFF" />
			</LinearLayout>
			<LinearLayout
				android:id="@+id/button2"
				android:layout_width="200dp"
				android:layout_height="55dp"
				android:layout_marginTop="4dp"
				android:layout_marginBottom="4dp"
				android:gravity="center_vertical"
				android:orientation="horizontal">
				<LinearLayout
					android:id="@+id/img2"
					android:layout_width="30dp"
					android:layout_height="30dp"
					android:layout_marginLeft="8dp"
					android:layout_marginRight="17dp"
					android:padding="8dp"
					android:background="@drawable/ic_settingfrm"
					android:orientation="horizontal"
					android:layout_gravity="right|center_vertical" />
				<TextView
					android:id="@+id/t2"
					android:layout_width="wrap_content"
					android:layout_height="wrap_content"
					android:padding="8dp"
					android:text="Setting"
					android:textSize="14sp"
					android:textColor="#FFFFFF" />
			</LinearLayout>
			<LinearLayout
				android:id="@+id/button3"
				android:layout_width="200dp"
				android:layout_height="55dp"
				android:layout_marginTop="2dp"
				android:layout_marginBottom="2dp"
				android:gravity="center_vertical"
				android:orientation="horizontal">
				<LinearLayout
					android:id="@+id/img3"
					android:layout_width="30dp"
					android:layout_height="30dp"
					android:layout_marginLeft="8dp"
					android:layout_marginRight="17dp"
					android:padding="8dp"
					android:background="@drawable/ic_support"
					android:orientation="horizontal"
					android:layout_gravity="right|center_vertical" />
				<TextView
					android:id="@+id/t3"
					android:layout_width="wrap_content"
					android:layout_height="wrap_content"
					android:padding="8dp"
					android:text="Support"
					android:textSize="14sp"
					android:textColor="#FFFFFF" />
			</LinearLayout>
			<LinearLayout
				android:id="@+id/button4"
				android:layout_width="200dp"
				android:layout_height="55dp"
				android:layout_marginTop="2dp"
				android:layout_marginBottom="2dp"
				android:gravity="center_vertical"
				android:orientation="horizontal">
				<LinearLayout
					android:id="@+id/img4"
					android:layout_width="30dp"
					android:layout_height="30dp"
					android:layout_marginLeft="8dp"
					android:layout_marginRight="17dp"
					android:padding="8dp"
					android:background="@drawable/ic_developer"
					android:gravity="left"
					android:orientation="horizontal"
					android:layout_gravity="right|center_vertical" />
				<TextView
					android:id="@+id/t4"
					android:layout_width="wrap_content"
					android:layout_height="wrap_content"
					android:padding="8dp"
					android:text="Developer"
					android:textSize="14sp"
					android:textColor="#FFFFFF" />
			</LinearLayout>
			<LinearLayout
				android:id="@+id/button5"
				android:layout_width="200dp"
				android:layout_height="55dp"
				android:layout_marginTop="2dp"
				android:layout_marginBottom="2dp"
				android:gravity="center_vertical"
				android:orientation="horizontal">
				<LinearLayout
					android:id="@+id/img5"
					android:layout_width="30dp"
					android:layout_height="30dp"
					android:layout_marginLeft="8dp"
					android:layout_marginRight="17dp"
					android:padding="8dp"
					android:background="@drawable/ic_privacy"
					android:orientation="horizontal"
					android:layout_gravity="right|center_vertical" />
				<TextView
					android:id="@+id/t5"
					android:layout_width="wrap_content"
					android:layout_height="wrap_content"
					android:padding="8dp"
					android:text="Privacy"
					android:textSize="14sp"
					android:textColor="#FFFFFF" />
			</LinearLayout>
			<LinearLayout
				android:id="@+id/button6"
				android:layout_width="200dp"
				android:layout_height="55dp"
				android:gravity="center_vertical"
				android:orientation="horizontal">
				<LinearLayout
					android:id="@+id/img6"
					android:layout_width="30dp"
					android:layout_height="30dp"
					android:layout_marginLeft="8dp"
					android:layout_marginRight="15dp"
					android:padding="8dp"
					android:background="@drawable/ic_rate"
					android:orientation="horizontal"
					android:layout_gravity="right|center_vertical" />
				<TextView
					android:id="@+id/t6"
					android:layout_width="wrap_content"
					android:layout_height="wrap_content"
					android:padding="8dp"
					android:text="Rate"
					android:textSize="14sp"
					android:textColor="#FFFFFF" />
			</LinearLayout>
		</LinearLayout>
	</LinearLayout>
</LinearLayout>
