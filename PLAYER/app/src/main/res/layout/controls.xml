<LinearLayout
	xmlns:android="http://schemas.android.com/apk/res/android"
	xmlns:app="http://schemas.android.com/apk/res-auto"
	xmlns:tools="http://schemas.android.com/tools"
	android:layout_width="match_parent"
	android:layout_height="match_parent"
	android:orientation="vertical">
	<LinearLayout
		android:id="@+id/linear1"
		android:layout_width="match_parent"
		android:layout_height="match_parent"
		android:gravity="center_horizontal"
		android:orientation="vertical"
		android:layout_weight="1"
		android:layout_centerInParent="true">
		<LinearLayout
			android:id="@+id/tab"
			android:layout_width="match_parent"
			android:layout_height="wrap_content"
			android:padding="8dp"
			android:gravity="center_vertical"
			android:orientation="horizontal">
			<ImageView
				android:id="@+id/back"
				android:focusable="false"
				android:layout_width="40dp"
				android:layout_height="20dp"
				android:src="@drawable/arrowback_1"
				android:scaleType="fitCenter" />
			<TextView
				android:id="@+id/textview1"
				android:focusable="false"
				android:layout_width="match_parent"
				android:layout_height="wrap_content"
				android:gravity="left"
				android:text="TextView"
				android:textSize="14sp"
				android:textStyle="bold"
				android:textColor="#FFFFFF"
				android:layout_weight="1" />
		</LinearLayout>
		<LinearLayout
			android:id="@+id/control"
			android:layout_width="match_parent"
			android:layout_height="wrap_content"
			android:gravity="center_horizontal|center_vertical"
			android:orientation="horizontal"
			android:layout_weight="1">
			<LinearLayout
				android:id="@+id/linear6"
				android:layout_width="wrap_content"
				android:layout_height="wrap_content"
				android:gravity="center_horizontal|center_vertical"
				android:orientation="horizontal"
				android:layout_weight="1">
				<ImageView
					android:id="@+id/exo_rew"
					android:focusable="false"
					android:layout_width="28dp"
					android:layout_height="30dp"
					android:layout_margin="10dp"
					android:src="@drawable/p100"
					android:scaleType="centerCrop"
					android:layout_gravity="center_horizontal|center_vertical" />
			</LinearLayout>
			<LinearLayout
				android:id="@+id/linear7"
				android:layout_width="wrap_content"
				android:layout_height="wrap_content"
				android:gravity="center_horizontal|center_vertical"
				android:orientation="horizontal">
				<ImageView
					android:id="@+id/exo_pause"
					android:focusable="false"
					android:layout_width="28dp"
					android:layout_height="55dp"
					android:layout_margin="10dp"
					android:src="@drawable/img_1"
					android:scaleType="fitCenter" />
				<ImageView
					android:id="@+id/exo_play"
					android:focusable="false"
					android:layout_width="28dp"
					android:layout_height="55dp"
					android:layout_margin="10dp"
					android:src="@drawable/img_2"
					android:scaleType="fitCenter" />
			</LinearLayout>
			<LinearLayout
				android:id="@+id/linear8"
				android:layout_width="wrap_content"
				android:layout_height="wrap_content"
				android:gravity="center_horizontal|center_vertical"
				android:orientation="horizontal"
				android:layout_weight="1">
				<ImageView
					android:id="@+id/exo_ffwd"
					android:focusable="false"
					android:layout_width="28dp"
					android:layout_height="30dp"
					android:layout_margin="10dp"
					android:src="@drawable/p10"
					android:scaleType="centerCrop"
					android:layout_gravity="center_horizontal|center_vertical" />
			</LinearLayout>
		</LinearLayout>
		<LinearLayout
			android:id="@+id/tool"
			android:layout_width="match_parent"
			android:layout_height="wrap_content"
			android:paddingRight="20dp"
			android:gravity="right|center_vertical"
			android:orientation="horizontal">
			<LinearLayout
				android:id="@+id/lineartools"
				android:layout_width="wrap_content"
				android:layout_height="wrap_content"
				android:gravity="center_horizontal|center_vertical"
				android:orientation="horizontal"
				android:weightSum="1"
				android:layout_gravity="center_horizontal|center_vertical">
				<ImageView
					android:id="@+id/cast"
					android:focusable="false"
					android:layout_width="28dp"
					android:layout_height="28dp"
					android:layout_margin="10dp"
					android:src="@drawable/casting"
					android:scaleType="centerCrop"
					android:layout_gravity="center_horizontal|center_vertical" />
				<ImageView
					android:id="@+id/imageview3"
					android:focusable="false"
					android:layout_width="28dp"
					android:layout_height="28dp"
					android:layout_margin="10dp"
					android:src="@drawable/hqhq"
					android:scaleType="centerCrop"
					android:layout_gravity="center_vertical" />
				<ImageView
					android:id="@+id/settingss"
					android:focusable="false"
					android:layout_width="28dp"
					android:layout_height="28dp"
					android:layout_margin="10dp"
					android:src="@drawable/ic_arrow_drop_up_white"
					android:scaleType="centerCrop"
					android:layout_gravity="center_vertical" />
				<ImageView
					android:id="@+id/bt_fullscreen"
					android:focusable="false"
					android:layout_width="28dp"
					android:layout_height="48dp"
					android:layout_margin="10dp"
					android:padding="10dp"
					android:src="@drawable/ic_screen_rotation_white"
					android:scaleType="centerCrop" />
				<ImageView
					android:id="@+id/imageview2"
					android:focusable="false"
					android:layout_width="28dp"
					android:layout_height="25dp"
					android:layout_margin="10dp"
					android:src="@drawable/ic_file_download_white"
					android:scaleType="centerCrop"
					android:layout_gravity="center_vertical" />
				<ImageView
					android:id="@+id/pip"
					android:focusable="false"
					android:layout_width="28dp"
					android:layout_height="25dp"
					android:layout_margin="10dp"
					android:src="@drawable/pip"
					android:scaleType="centerCrop"
					android:layout_gravity="center_vertical" />
				<ImageView
					android:id="@+id/zoom"
					android:focusable="false"
					android:layout_width="28dp"
					android:layout_height="25dp"
					android:layout_margin="10dp"
					android:src="@drawable/ic_aspect_ratio_white"
					android:scaleType="centerCrop"
					android:layout_gravity="center_vertical" />
			</LinearLayout>
		</LinearLayout>
	</LinearLayout>
	<LinearLayout
		android:id="@+id/linear2"
		android:layout_width="match_parent"
		android:layout_height="wrap_content"
		android:orientation="vertical"
		android:layout_alignParentBottom="true">
		<LinearLayout
			android:id="@+id/linear3"
			android:layout_width="match_parent"
			android:layout_height="wrap_content"
			android:layout_marginLeft="10dp"
			android:layout_marginRight="10dp"
			android:padding="8dp"
			android:gravity="center_horizontal|center_vertical"
			android:orientation="horizontal">
			<TextView
				android:id="@+id/exo_position"
				android:focusable="false"
				android:layout_width="wrap_content"
				android:layout_height="wrap_content"
				android:padding="8dp"
				android:text="00"
				android:textSize="16sp"
				android:textColor="#FFFFFF" />
			<TextView
				android:id="@+id/textview2"
				android:focusable="false"
				android:layout_width="wrap_content"
				android:layout_height="wrap_content"
				android:textSize="12sp"
				android:textColor="#FFFFFF" />
			<LinearLayout
				android:id="@+id/linr"
				android:layout_width="match_parent"
				android:layout_height="25dp"
				android:gravity="center_horizontal"
				android:orientation="horizontal"
				android:layout_weight="1">
				<com.google.android.exoplayer2.ui.DefaultTimeBar
					android:id="@+id/exo_progress"
					android:focusable="false"
					android:layout_width="match_parent"
					android:layout_height="wrap_content"
					android:layout_marginLeft="10dp"
					android:layout_marginRight="10dp"
					android:translationY="4.2dp"
					android:layout_gravity="left"
					android:layout_marginTop="8dp"
					app:unplayed_color="#45424E"
					app:buffered_color="#95989F"
					app:played_color="#FF0000" />
			</LinearLayout>
			<TextView
				android:id="@+id/exo_duration"
				android:focusable="false"
				android:layout_width="wrap_content"
				android:layout_height="wrap_content"
				android:padding="8dp"
				android:text="00"
				android:textSize="16sp"
				android:textColor="#FFFFFF" />
		</LinearLayout>
	</LinearLayout>
</LinearLayout>
